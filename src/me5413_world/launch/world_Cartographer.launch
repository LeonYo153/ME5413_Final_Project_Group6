<launch>
    <!-- Using the simulation clock -->
    <param name="/use_sim_time" value="true"/>

    <!-- Load the project world into Gazebo -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name" value="$(find me5413_world)/worlds/me5413_project_2526.world"/>
        <arg name="debug" value="false" />
        <arg name="gui" value="true" />
        <arg name="paused" value="false"/>
        <arg name="use_sim_time" value="true"/>
        <arg name="headless" value="false"/>
    </include>

    <!-- Add our jackal robot into the simulation -->
    <include file="$(find me5413_world)/launch/include/spawn_jackal.launch"/>


    <param name="planar_box_description" 
            command="$(find xacro)/xacro --inorder '$(find me5413_world)/launch/include/planar_box.urdf.xacro'" />

    
    <!-- 1st floor apriltag -->
    <node name="spawn_tag_0" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00000 -sdf -model tag_0 -x -24.8 -y -7.5 -z 0.216 -R 0 -P -1.57 -Y 0" />

    <!-- <node name="spawn_tag_1" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00001 -sdf -model tag_1 -x -0.2 -y -3.5 -z 0.216 -R 0 -P -1.57 -Y 0" /> -->

     <!-- <node name="spawn_tag_2" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00002 -sdf -model tag_2 -x -0.2 -y 6.5 -z 0.216 -R 0 -P -1.57 -Y 0" /> -->

    <!-- <node name="spawn_tag_3" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00003 -sdf -model tag_3 -x -19.8 -y 4.0 -z 0.216 -R 0 -P -1.57 -Y 0" /> -->

    
    <!-- slope apriltag -->
    <node name="spawn_tag_4" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00004 -sdf -model tag_4 -x -0.50 -y -10.20 -z 0.216 -R 1.5708 -P 0 -Y 0" />

    <node name="spawn_tag_5" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00005 -sdf -model tag_5 -x 2.80 -y -13.00 -z 0.216 -R 1.5708 -P 0 -Y 0" />

    <node name="spawn_tag_6" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00006 -sdf -model tag_6 -x 17.8 -y -13.00 -z 2.86 -R 1.5708 -P 0 -Y 0" />

    <!-- <node name="spawn_tag_7" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00007 -sdf -model tag_7 -x 19.8 -y -11.50 -z 2.86 -R 0 -P -1.57 -Y 0" /> -->

    <node name="spawn_tag_8" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00008 -sdf -model tag_8 -x 18.2 -y -9.00 -z 2.86 -R 0 -P -1.57 -Y 0" />

    <!-- <node name="spawn_tag_9" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00009 -sdf -model tag_9 -x 17.8 -y -13.00 -z 2.86 -R 1.5708 -P 0 -Y 0" />  -->


    <!-- 2nd floor apriltag -->
    <!-- <node name="spawn_tag_10" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00010 -sdf -model tag_10 -x 19.8 -y -0.4 -z 2.86 -R 0 -P -1.57 -Y 0" /> 

    <node name="spawn_tag_11" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00011 -sdf -model tag_11 -x 18.0 -y 9.5 -z 2.86 -R 1.57 -P 0 -Y 0" />
    
    <node name="spawn_tag_12" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00012 -sdf -model tag_12 -x 14.0 -y -9.8 -z 2.86 -R 1.57 -P 0 -Y 0" />

    <node name="spawn_tag_13" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00013 -sdf -model tag_13 -x 12.3 -y -0.4 -z 2.86 -R 0 -P -1.57 -Y 0" />

    <node name="spawn_tag_14" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00014 -sdf -model tag_14 -x 9.0 -y 9.5 -z 2.86 -R 1.57 -P 0 -Y 0" />

    <node name="spawn_tag_15" pkg="gazebo_ros" type="spawn_model" 
        args="-database Apriltag36_11_00015 -sdf -model tag_15 -x 9.0 -y -9.8 -z 2.86 -R 1.57 -P 0 -Y 0" /> -->

    <!-- keyboard control -->

    <!-- <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" respawn="true"/>
    <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/gmapping.rviz" output="log" respawn="true"/> -->
    
    <!-- comment the following out if you do not want the big red obstacle for mapping etc-->
    <!-- <node name="spawn_box" pkg="gazebo_ros" type="spawn_model" output="screen"
            args="-urdf 
                -param planar_box_description 
                -model planar_box 
                -x 6.0 -y 0.0 -z 3.5" /> -->
    
    <!-- Load the destination configuration -->
    <!-- <rosparam command="load" file="$(find me5413_world)/config/config.yaml" /> -->

</launch>
