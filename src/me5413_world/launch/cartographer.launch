<!-- this is offline Cartographer -->
<launch>
  <param name="/use_sim_time" value="true" />

  <node name="cartographer_offline_node" pkg="cartographer_ros"
      type="cartographer_offline_node" args="
          --configuration_directory $(find me5413_world)/config
          --configuration_basenames cartographer.lua
          --bag_filenames $(find me5413_world)/CartographerSrc/1stFloor.bag
          --load_state_filename $(find me5413_world)/CartographerSrc/2nd_slope.pbstream"
      output="screen">
    <remap from="scan" to="/front/scan" />
    <remap from="odom" to="/odometry/filtered" />
    <remap from="imu" to="/imu/data" />
    <remap from="landmark" to="/landmarks" /> 
  </node>

  <node name="cartographer_occupancy_grid_node" pkg="cartographer_ros"
      type="cartographer_occupancy_grid_node" args="-resolution 0.05" />

  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/gmapping.rviz" />

</launch>

  <!-- load_state_filename /home/ruiqi/ME5413_Final_Project/slope_map.pbstream" -->
  <!--save_state_filename /home/ruiqi/ME5413_Final_Project/slopeUpDown.pbstream -->
  <!--bag_filenames /home/ruiqi/ME5413_Final_Project/1stFloor.bag -->