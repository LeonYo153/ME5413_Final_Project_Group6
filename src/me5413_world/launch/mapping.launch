<launch>

  <node name="teleop_twist_keyboard"
        pkg="teleop_twist_keyboard"
        type="teleop_twist_keyboard.py"
        launch-prefix="xterm -e"
        output="screen"/>

  <node pkg="rtabmap_slam"
        type="rtabmap"
        name="rtabmap"
        args="--delete_db_on_start"
        output="screen">

    <!-- Basic subscriptions -->
    <param name="frame_id" value="base_link"/>
    <param name="subscribe_rgb" value="true"/>
    <param name="subscribe_depth" value="true"/>
    <param name="subscribe_scan_cloud" value="true"/>
    <param name="subscribe_scan" value="false"/>
    <param name="subscribe_odom_info" value="false"/>

    <!-- Sync -->
    <param name="approx_sync" value="true"/>
    <param name="queue_size" value="30"/>
    <param name="wait_for_transform_duration" value="0.2"/>

    <!-- Occupancy grid / mapping -->
    <param name="Grid/Sensor" type="string" value="2"/>
    <param name="Grid/FromDepth" type="string" value="true"/>
    <param name="Grid/3D" type="string" value="true"/>
    <param name="Grid/RayTracing" type="string" value="true"/>
    <param name="Grid/CellSize" type="string" value="0.05"/>
    <param name="Grid/RangeMax" type="string" value="6.0"/>

    <!-- Key changes for ramp / slope handling -->
    <param name="Grid/NormalsSegmentation" type="string" value="true"/>
    <param name="Grid/MaxGroundAngle" type="string" value="25"/>
    <param name="Grid/MinGroundHeight" type="string" value="-0.15"/>
    <param name="Grid/MaxGroundHeight" type="string" value="0.30"/>
    <param name="Grid/MaxObstacleHeight" type="string" value="2.50"/>
    <param name="Grid/MapFrameProjection" type="string" value="false"/>

    <!-- Keep a complete 2D map: no altitude slicing -->
    <param name="GridGlobal/AltitudeDelta" type="string" value="0"/>

    <!-- Registration: visual + ICP -->
    <param name="Reg/Strategy" type="string" value="2"/>
    <param name="Reg/Force3DoF" type="string" value="false"/>

    <!-- ICP -->
    <param name="Icp/VoxelSize" type="string" value="0.05"/>
    <param name="Icp/MaxCorrespondenceDistance" type="string" value="0.10"/>
    <param name="Icp/PointToPlane" type="string" value="true"/>
    <param name="Icp/Iterations" type="string" value="20"/>

    <!-- Graph optimization -->
    <param name="Optimizer/Strategy" type="string" value="1"/>
    <param name="Optimizer/Robust" type="string" value="true"/>

    <!-- Help local loop closures -->
    <param name="RGBD/ProximityBySpace" type="string" value="true"/>

    <!-- Depth -->
    <param name="Vis/MaxDepth" type="string" value="5.0"/>

    <!-- Topic remaps -->
    <remap from="rgb/image" to="/front_rgbd/rgb/image_raw"/>
    <remap from="depth/image" to="/front_rgbd/depth/image_raw"/>
    <remap from="rgb/camera_info" to="/front_rgbd/rgb/camera_info"/>
    <remap from="scan_cloud" to="/mid/points"/>
    <remap from="odom" to="/odometry/filtered"/>
    <remap from="grid_map" to="/map"/>
  </node>

  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find me5413_world)/rviz/rtabmap_mapping.rviz"
        output="screen"/>
</launch>